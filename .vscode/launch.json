{
    "version": "0.2.0",
    "configurations": [    
        {
            "name": "GDB: Debug mit BlastEm",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/out/rom.out",
            "stopAtEntry": true,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "${env:GDK}\\bin\\gdb.exe",
            "miDebuggerServerAddress": "localhost:6868",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "text": "set directories '${workspaceFolder}'"
                }
            ],
            "sourceFileMap": {
                "d:\\apps\\sgdk\\src\\": "${env:GDK}\\src\\"
            }
        }
    ]
}